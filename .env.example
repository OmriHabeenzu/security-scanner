# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-string

# Database
DATABASE_URL=sqlite:///security_scanner.db

# External APIs (get your own keys)
GOOGLE_SAFE_BROWSING_API_KEY=your-google-safe-browsing-key
ABUSEIPDB_API_KEY=your-abuseipdb-key
VIRUSTOTAL_API_KEY=your-virustotal-key

# Email Configuration (for PDF report emails)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# Upload Settings
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=exe,dll,pdf,doc,docx,txt,zip,rar

# Rate Limiting
MAX_GUEST_SCANS_PER_DAY=10
MAX_USER_SCANS_PER_DAY=100
